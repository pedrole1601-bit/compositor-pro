{
  "name": "compositor-pro-v2",
  "version": "2.0.0",
  "description": "Real-time multi-frame visual composition system for Holyrics",
  "main": "dist/server/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/index.ts",
    "dev:client": "vite",
    "build": "npm run build:server && npm run build:client",
    "build:server": "tsc",
    "build:client": "vite build",
    "test": "vitest",
    "start": "node dist/server/index.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"src/**/*.{ts,html,css}\""
  },
  "dependencies": {
    "express": "^5.2.0",
    "ws": "^8.20.0",
    "multer": "^2.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.9",
    "@types/ws": "^8.5.14",
    "@typescript-eslint/eslint-plugin": "^8.26.0",
    "@typescript-eslint/parser": "^8.26.0",
    "concurrently": "^9.1.2",
    "eslint": "^9.21.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.0",
    "vitest": "^3.0.7"
  }
}
